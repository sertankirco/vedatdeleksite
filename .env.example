# PostgreSQL bağlantı URL'i (Railway, Supabase, Neon, vb.)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# JWT / Cookie şifrelemesi için gizli anahtar
JWT_SECRET=your-secret-key-here

# Google OAuth (opsiyonel)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Site sahibinin OpenID'si (admin rolü için)
OWNER_OPEN_ID=

# Forge API (Manus entegrasyonu)
BUILT_IN_FORGE_API_URL=
BUILT_IN_FORGE_API_KEY=
